   "source": [
    "import cohere\n",
    "import os\n",
    "co = cohere.ClientV2(os.getenv(\"COHERE_API_KEY\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d368169a",
   "metadata": {},
   "outputs": [],
   "source": [
    "message = input(\"Enter your message: \")\n",
    "\n",
    "response = co.chat(\n",
    "    model= \"command-a-03-2025\",\n",
    "    messages= [{'role': 'user', 'content': message}]\n",
    "    )\n",
    "\n",
    "print(response.message.content[0].text)"
   ]
  }
